# Copy to .env on the VPS and replace all secrets before starting Docker Compose.
PORT=3001
ORCHESTRATOR_BIND=127.0.0.1
APP_DOMAIN=ai.example.com
API_KEY=replace-with-long-random-api-key

STUB_EXTERNAL_SERVICES=false
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=holtkamp_knowledge
QDRANT_API_KEY=replace-with-long-random-qdrant-api-key
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE=Cosine

# If local LLM/embedding services run on the VPS host, keep host.docker.internal.
# If they run on another machine, use its Tailscale/VPN IP or DNS name.
LLM_SMALL_URL=http://host.docker.internal:1234/v1/chat/completions
LLM_MEDIUM_URL=http://host.docker.internal:1235/v1/chat/completions
LLM_LARGE_URL=http://host.docker.internal:1236/v1/chat/completions
LLM_SMALL_MODEL=local-7b
LLM_MEDIUM_MODEL=local-13b
LLM_LARGE_MODEL=local-32b
EMBEDDING_URL=http://host.docker.internal:11434/api/embeddings
EMBEDDING_MODEL=nomic-embed-text

CORS_ALLOWED_ORIGINS=https://ai.example.com
BFF_DEV_LOGIN_KEY=replace-with-login-key
BFF_SESSION_SECRET=replace-with-openssl-rand-hex-32
BFF_SESSION_COOKIE_NAME=bff_session
BFF_SESSION_TTL_SECONDS=28800
BFF_COOKIE_SECURE=true

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
LARGE_MODEL_ALLOWED_USERS=
LARGE_MODEL_ALLOWED_API_KEYS=

CHAT_CACHE_ENABLED=true
CHAT_CACHE_TTL_SECONDS=300
CHAT_CACHE_MAX_ENTRIES=500
HYBRID_RETRIEVAL_ENABLED=true
SPARSE_SEARCH_ENABLED=true
SPARSE_SEARCH_LIMIT=8
RANK_FUSION_K=60
SEMANTIC_ANCHORS_ENABLED=true
SEMANTIC_ANCHORS_REGISTRY_PATH=data/anchors.json
SEMANTIC_ANCHORS_MIN_SCORE=2
SEMANTIC_ANCHORS_MAX_CANDIDATES=3
TOOL_CALLING_ENABLED=true
TOOL_SEARCH_LIMIT=3

ADMIN_PRIVATE_NETWORKS_ONLY=true
ADMIN_ALLOWED_IPS=127.0.0.1,::1

EXTERNAL_REQUEST_TIMEOUT_MS=10000
EXTERNAL_RETRY_ATTEMPTS=1
EXTERNAL_RETRY_DELAY_MS=150
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_COOLDOWN_MS=30000

BENCHMARK_TIMEOUT_MS=30000
BENCHMARK_PRICE_INPUT_PER_1K=0
BENCHMARK_PRICE_OUTPUT_PER_1K=0
BENCHMARK_RAG_MODEL=medium
